# Server
NODE_ENV=development
PORT=5000

# Database (PostgreSQL credentials)
DATABASE_URL=postgresql://postgres:2121@localhost:5432/ecommerce_db

# Alternative: individual credentials (used if DATABASE_URL not set)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=2121
DB_NAME=ecommerce_db

# JWT (change in production)
JWT_ACCESS_SECRET=your-super-secret-access-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
JWT_ISSUER=e-commerce-api

# Bcrypt
BCRYPT_ROUNDS=12

# OpenAI (optional - for AI recommendations)
OPENAI_API_KEY=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Database Auto-init
DB_AUTO_INIT=true
DB_SCHEMA_PATH=schema/schema.sql
DB_CHECK_TABLE=users
