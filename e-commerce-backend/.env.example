# Server
NODE_ENV=development
PORT=5000

# Database (use DATABASE_URL or individual vars)
DATABASE_URL=postgresql://user:password@localhost:5432/ecommerce_db

# Optional: individual credentials (overridden by DATABASE_URL)
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=user
# DB_PASSWORD=password
# DB_NAME=ecommerce_db

# Optional: pool tuning (defaults shown)
# DB_POOL_SIZE=20
# DB_POOL_MIN=2
# DB_IDLE_TIMEOUT=30000
# DB_CONNECTION_TIMEOUT=10000
# DB_SSL=false

# Schema auto-init (runs schema.sql on startup if check table doesn't exist)
# DB_SCHEMA_PATH=schema/schema.sql
# DB_CHECK_TABLE=users
# DB_AUTO_INIT=true

# JWT
JWT_ACCESS_SECRET=your-super-secret-access-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
JWT_ISSUER=e-commerce-api

# Bcrypt
BCRYPT_ROUNDS=12

# OpenAI (for AI product recommendations)
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
